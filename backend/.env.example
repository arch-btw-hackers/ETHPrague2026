# PostgreSQL connection string consumed by Prisma.
DATABASE_URL="postgresql://vibetrack:vibetrack@localhost:5432/vibetrack?schema=public"

# HTTP port for the Intelligence Hub API.
PORT=4000

# Optional: shared secret expected on the X-Device-Key header from the
# hardware tracker (SpaceComputer). Leave empty to disable in dev.
DEVICE_API_KEY=

# Optional: provider key for the future "Supreme Judge" LLM verifier.
# (Anthropic / OpenAI compatible — read by services/judge.ts.)
JUDGE_API_KEY=
JUDGE_MODEL=claude-sonnet-4

# AI Insights (services/insights.ts).
# Without this the dashboard falls back to a deterministic heuristic.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
